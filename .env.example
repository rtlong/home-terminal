# Copy this to .env and fill in your values.
# All variables are optional — the app starts without them but features
# that depend on missing credentials will be silently disabled.

# CalDAV (Apple iCloud: use an app-specific password, not your Apple ID password)
CALDAV_URL=https://caldav.icloud.com
CALDAV_USERNAME=you@example.com
CALDAV_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Google Maps (Distance Matrix + Geocoding APIs must be enabled)
GOOGLE_MAPS_API_KEY=AIzaSy...

# MQTT broker (Home Assistant)
MQTT_HOST=homeassistant.lan
MQTT_USERNAME=home-terminal
MQTT_PASSWORD=your-mqtt-password

# Display power control (Wayland)
# DISPLAY_OUTPUT is the wlroots output name, e.g. HDMI-A-1, eDP-1
DISPLAY_OUTPUT=HDMI-A-1
# DISPLAY_CONTROL_SCHEME: swaymsg (recommended), wlopm, or wlr-randr
DISPLAY_CONTROL_SCHEME=swaymsg

# HTTP port (default: 46548)
# PORT=46548
